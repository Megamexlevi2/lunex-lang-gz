val native = @import("internal.native")
val _state = {
  suites: [],
  current: null,
  only: false
}

fn describe(name, block) {
  val suite = {
    name: name,
    tests: [],
    beforeEach: null,
    afterEach: null,
    beforeAll: null,
    afterAll: null,
    only: false
  }
  val prev = _state.current
  _state.current = suite
  _state.suites.push(suite)
  block()
  _state.current = prev
}

fn it(name, testCallback) {
  val entry = { name: name, callback: testCallback, skip: false, only: false }
  if _state.current !== null {
    _state.current.tests.push(entry)
  } else {
    _state.suites.push({ name: "", tests: [entry], beforeEach: null, afterEach: null, beforeAll: null, afterAll: null })
  }
}

fn test(name, testCallback) {
  it(name, testCallback)
}

fn skip(name, testCallback) {
  val entry = { name: name, callback: testCallback, skip: true, only: false }
  if _state.current !== null {
    _state.current.tests.push(entry)
  }
}

fn beforeEach(hook) {
  if _state.current !== null { _state.current.beforeEach = hook }
}

fn afterEach(hook) {
  if _state.current !== null { _state.current.afterEach = hook }
}

fn beforeAll(hook) {
  if _state.current !== null { _state.current.beforeAll = hook }
}

fn afterAll(hook) {
  if _state.current !== null { _state.current.afterAll = hook }
}

fn assertionError(message) {
  { message: message, name: "AssertionError" }
}

val expect = fn(actual) {
  fn _fail(msg) {
    throw assertionError(msg)
  }

  fn _toStr(v) {
    try { JSON.stringify(v) } catch e { "" + v }
  }

  val negate = {
    toBe: fn(expected) {
      if actual === expected { _fail("expected " + _toStr(actual) + " not to be " + _toStr(expected)) }
    },
    toEqual: fn(expected) {
      if _toStr(actual) === _toStr(expected) { _fail("expected values not to be equal") }
    },
    toBeTruthy: fn() {
      if actual { _fail("expected " + _toStr(actual) + " not to be truthy") }
    },
    toBeNull: fn() {
      if actual === null { _fail("expected value not to be null") }
    },
    toBeUndefined: fn() {
      if actual === undefined { _fail("expected value not to be undefined") }
    },
    toThrow: fn() {
      if typeof actual !== "function" { _fail("expected a function") }
      var threw = false
      try { actual() } catch e { threw = true }
      if threw { _fail("expected function not to throw") }
    }
  }

  val matchers = {
    toBe: fn(expected) {
      if actual !== expected {
        _fail("expected " + _toStr(actual) + " to be " + _toStr(expected))
      }
    },
    toEqual: fn(expected) {
      if _toStr(actual) !== _toStr(expected) {
        _fail("expected " + _toStr(actual) + " to equal " + _toStr(expected))
      }
    },
    toBeTruthy: fn() {
      if not actual { _fail("expected " + _toStr(actual) + " to be truthy") }
    },
    toBeFalsy: fn() {
      if actual { _fail("expected " + _toStr(actual) + " to be falsy") }
    },
    toBeNull: fn() {
      if actual !== null { _fail("expected value to be null") }
    },
    toBeUndefined: fn() {
      if actual !== undefined { _fail("expected value to be undefined") }
    },
    toBeDefined: fn() {
      if actual === undefined { _fail("expected value to be defined") }
    },
    toBeGreaterThan: fn(n) {
      if actual <= n { _fail("expected " + actual + " to be greater than " + n) }
    },
    toBeGreaterThanOrEqual: fn(n) {
      if actual < n { _fail("expected " + actual + " to be >= " + n) }
    },
    toBeLessThan: fn(n) {
      if actual >= n { _fail("expected " + actual + " to be less than " + n) }
    },
    toBeLessThanOrEqual: fn(n) {
      if actual > n { _fail("expected " + actual + " to be <= " + n) }
    },
    toContain: fn(item) {
      val found = Array.isArray(actual) ? actual.includes(item) : ("" + actual).includes("" + item)
      if not found { _fail("expected value to contain " + _toStr(item)) }
    },
    toHaveLength: fn(n) {
      if actual === undefined or actual.length !== n {
        _fail("expected length " + n + " but got " + (actual !== undefined ? actual.length : "undefined"))
      }
    },
    toThrow: fn() {
      if typeof actual !== "function" { _fail("expected a function") }
      var threw = false
      try { actual() } catch e { threw = true }
      if not threw { _fail("expected function to throw") }
    },
    toMatchObject: fn(expected) {
      each k in Object.keys(expected) {
        if _toStr(actual[k]) !== _toStr(expected[k]) {
          _fail("expected object to match: key " + k)
        }
      }
    },
    toBeInstanceOf: fn(constructor) {
      if typeof actual !== "object" {
        _fail("expected object instance")
      }
    },
    not: negate
  }

  matchers
}

fn run() {
  var totalPassed = 0
  var totalFailed = 0
  var totalSkipped = 0
  each suite in _state.suites {
    if suite.name !== "" {
      native.io.log("\n  " + suite.name)
    }
    if suite.beforeAll !== null {
      try { suite.beforeAll() } catch e {}
    }
    each entry in suite.tests {
      if entry.skip {
        totalSkipped += 1
        native.io.log("    \x1b[33mSKIP\x1b[0m  " + entry.name)
        continue
      }
      if suite.beforeEach !== null {
        try { suite.beforeEach() } catch e {}
      }
      try {
        entry.callback()
        totalPassed += 1
        native.io.log("    \x1b[32mPASS\x1b[0m  " + entry.name)
      } catch err {
        totalFailed += 1
        native.io.log("    \x1b[31mFAIL\x1b[0m  " + entry.name)
        if err !== undefined and err.message !== undefined {
          native.io.log("          " + err.message)
        }
      }
      if suite.afterEach !== null {
        try { suite.afterEach() } catch e {}
      }
    }
    if suite.afterAll !== null {
      try { suite.afterAll() } catch e {}
    }
  }
  val icon = totalFailed === 0 ? "\x1b[32m✔\x1b[0m" : "\x1b[31m✗\x1b[0m"
  native.io.log("\n" + icon + " " + totalPassed + " passed, " + totalFailed + " failed, " + totalSkipped + " skipped")
  val suiteResults = _state.suites
  _state.suites = []
  _state.current = null
  { passed: totalPassed, failed: totalFailed, skipped: totalSkipped, suites: suiteResults }
}
