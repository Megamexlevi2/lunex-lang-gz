val native = @import("internal.native")
fn isString(v) { typeof v === "string" }
fn isNumber(v) { typeof v === "number" }
fn isBoolean(v) { typeof v === "boolean" }
fn isArray(v) { Array.isArray(v) }
fn isObject(v) {
  if v === null { false }
  if v === undefined { false }
  if typeof v !== "object" { false }
  if Array.isArray(v) { false }
  true
}
fn isNull(v) { v === null }
fn isDefined(v) { v !== undefined and v !== null }
fn isEmail(v) { native.validate.isEmail(v) }
fn isUrl(v) { native.validate.isUrl(v) }
fn isPhone(v) { native.validate.isPhone(v) }
fn isUUID(v) { native.validate.isUUID(v) }
fn isIPv4(v) { native.validate.isIPv4(v) }
fn isIPv6(v) { native.validate.isIPv6(v) }
fn isIP(v) { native.validate.isIP(v) }
fn isAlpha(v) { native.validate.isAlpha(v) }
fn isAlphanumeric(v) { native.validate.isAlphanumeric(v) }
fn isNumeric(v) { native.validate.isNumeric(v) }
fn isHex(v) { native.validate.isHex(v) }
fn isBase64(v) { native.validate.isBase64(v) }
fn isJSON(v) { native.validate.isJSON(v) }
fn isCreditCard(v) { native.validate.isCreditCard(v) }
fn isSlug(v) { native.validate.isSlug(v) }
fn isDate(v) { native.validate.isDate(v) }
fn isStrongPassword(v) { native.validate.isStrongPassword(v) }
fn test(v, pattern) { native.validate.matches(v, pattern) }
fn schema(definition) {
  fn(data) {
    native.validate.validate(data, definition)
  }
}
fn validate(data, rules) { native.validate.validate(data, rules) }
fn required(v) { v !== undefined and v !== null and v !== "" }
fn minLength(v, n) { typeof v === "string" and v.length >= n }
fn maxLength(v, n) { typeof v === "string" and v.length <= n }
fn inRange(n, lo, hi) { native.validate.range(n, lo, hi) }
