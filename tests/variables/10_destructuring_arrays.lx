// Lunex — array destructuring
// Extract elements from arrays into local bindings
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn getCoords() { [48.8566, 2.3522] }
fn main() {
  val [lat, lon] = getCoords()
  io.log("lat:", lat, "lon:", lon)
  val [r, g, b] = [255, 128, 0]
  io.log("rgb:", r, g, b)
  val [first, second] = ["alpha", "beta", "gamma"]
  io.log("first:", first, "second:", second)
  io.log("PASS destructuring_arrays")
}