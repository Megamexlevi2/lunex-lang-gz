// Lunex — object operations
// Literals, field access, nested objects
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  val user = { name: "Alice", age: 30, active: true }
  io.log("name:", user.name)
  io.log("age:", user.age)
  val address = { city: "London", country: "UK" }
  val profile = { user: user, address: address }
  io.log("city:", profile.address.city)
  io.log("PASS object_operations")
}