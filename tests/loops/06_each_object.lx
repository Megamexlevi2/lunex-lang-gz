// Lunex — each over object
// Iterating over key-value pairs
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  val config = { host: "localhost", port: "8080", debug: "true" }
  each key in config { io.log(" ", key, "=", config[key]) }
  io.log("PASS each_object")
}