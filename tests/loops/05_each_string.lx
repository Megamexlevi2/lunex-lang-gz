// Lunex — each over string
// Iterating over characters
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn countChar(str, target) {
  var count = 0
  each ch in str { if ch == target { count = count + 1 } }
  count
}
fn main() {
  each ch in "lunex" { io.log("char:", ch) }
  io.log("spaces:", countChar("hello world", " "))
  io.log("PASS each_string")
}