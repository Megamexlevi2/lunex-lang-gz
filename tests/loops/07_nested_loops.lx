// Lunex — nested loops
// while and each nested inside each other
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  io.log("3x3 table:")
  var i = 1
  while i <= 3 {
    var j   = 1
    var row = ""
    while j <= 3 {
      row = row + str(i * j) + " "
      j   = j + 1
    }
    io.log(row)
    i = i + 1
  }
  val grid  = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
  var total = 0
  each row in grid { each cell in row { total = total + cell } }
  io.log("grid sum:", total)
  io.log("PASS nested_loops")
}
