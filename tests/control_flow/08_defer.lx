// Lunex — defer
// Schedule cleanup code to run when function exits
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn simulateFile(name) {
  io.log("open:", name)
  defer { io.log("close:", name) }
  io.log("read:", name)
  io.log("process:", name)
}
fn multiDefer() {
  defer { io.log("defer 1") }
  defer { io.log("defer 2") }
  defer { io.log("defer 3") }
  io.log("body")
}
fn main() {
  simulateFile("data.csv")
  io.log("---")
  multiDefer()
  io.log("PASS defer")
}