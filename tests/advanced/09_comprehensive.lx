// Lunex — comprehensive integration
// Structs, closures, channels, match, and stdlib
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io       = @import("std.io")
val math     = @import("std.math")
val datetime = @import("std.datetime")
val crypto   = @import("std.crypto")
fn Job(id, payload) {
  struct {
    id      = id
    payload = payload
    status  = "pending"
    fn start()    { this.status = "running" }
    fn complete() { this.status = "done" }
    fn fail()     { this.status = "failed" }
    fn summary()  { "[" + this.id.slice(0, 8) + "] " + this.payload + " → " + this.status }
  }
}
fn processJob(job, ch) {
  job.start()
  if math.random() > 0.2 { job.complete() } else { job.fail() }
  ch.send(job)
}
fn main() {
  io.log("=== Lunex Integration Test ===")
  io.log("ts:", datetime.toTimestamp(datetime.now()))
  val defs = ["index-docs", "send-email", "compile-assets", "run-migrations", "warm-cache"]
  val ch   = channel()
  each def_ in defs {
    val j = Job(crypto.randomUUID(), def_)
    spawn fn() { processJob(j, ch) }()
  }
  var done   = 0
  var failed = 0
  var i      = 0
  while i < 5 {
    val j = ch.recv()
    io.log(j.summary())
    if j.status == "failed" { failed = failed + 1 }
    done = done + 1
    i    = i + 1
  }
  io.log("done:", done, "failed:", failed)
  io.log("=== PASS comprehensive ===")
}
