// Lunex — runtime introspection
// Inspect globals, version, and runtime state
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io      = @import("std.io")
val runtime = @import("runtime")
fn main() {
  io.log("version:", runtime.version())
  io.log("globals:", runtime.globals())
  runtime.setGlobal("LUNEX_TEST_KEY", "lunex_value")
  io.log("has:", runtime.hasGlobal("LUNEX_TEST_KEY"))
  io.log("get:", runtime.getGlobal("LUNEX_TEST_KEY"))
  io.log("PASS runtime_inspect")
}