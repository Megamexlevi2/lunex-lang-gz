// Lunex — conditional return via if/else expressions
// Lunex uses last-expression semantics; if/else controls the returned value
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn safeDiv(a, b) {
  if b == 0 { "error: division by zero" } else { a / b }
}
fn firstEven(arr) {
  var found = null
  each n in arr {
    if n % 2 == 0 && found == null { found = n }
  }
  found
}
fn main() {
  io.log("safeDiv(10,2):", safeDiv(10, 2))
  io.log("safeDiv(10,0):", safeDiv(10, 0))
  io.log("firstEven([1,3,5,4]):", firstEven([1, 3, 5, 4]))
  io.log("firstEven([1,3,5]):", firstEven([1, 3, 5]))
  io.log("PASS fn_explicit_return")
}
