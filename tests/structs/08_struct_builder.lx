// Lunex — builder pattern
// Fluent query builder using closure state and method chaining
// Lunex v0.7.1 · github.com/Megamexlerei2/lunex-lang-gz

val io = @import("std.io")

fn QueryBuilder() {
  var table_ = ""
  var conds  = []
  var cols   = ["*"]
  var lim    = null

  struct {
    fn from(t) {
      table_ = t
      this
    }

    fn select(c) {
      cols = c
      this
    }

    fn where(c) {
      conds.push(c)
      this
    }

    fn limit(n) {
      lim = n
      this
    }

    fn build() {
      var q = "SELECT " + cols.join(", ") + " FROM " + table_
      if conds.length > 0 {
        q = q + " WHERE " + conds.join(" AND ")
      }
      if lim != null {
        q = q + " LIMIT " + str(lim)
      }
      q
    }
  }
}

fn main() {
  val q = QueryBuilder()

  io.log(
    q.from("users")
     .select(["id", "name", "email"])
     .where("active = true")
     .where("age > 18")
     .limit(10)
     .build()
  )

  io.log("PASS struct_builder")
}
