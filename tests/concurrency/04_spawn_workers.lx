// Lunex — spawn — worker pool
// Fixed pool processing a queue
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn worker(id, jobs, results) {
  while true {
    val job = jobs.recv()
    if job == null { break }
    results.send({ w: id, r: job * job })
  }
}
fn main() {
  val jobs = channel(); val results = channel()
  var w = 1
  while w <= 3 { val wid = w; spawn fn() { worker(wid, jobs, results) }(); w = w + 1 }
  var j = 1
  while j <= 6 { jobs.send(j); j = j + 1 }
  jobs.send(null); jobs.send(null); jobs.send(null)
  var k = 0
  while k < 6 { val r = results.recv(); io.log("worker", r.w, "→", r.r); k = k + 1 }
  io.log("PASS spawn_workers")
}