// Lunex — channel — fan-out
// Multiple goroutines writing to one channel
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  val ch   = channel()
  val nums = [1, 2, 3, 4, 5]
  each n in nums {
    val num = n
    spawn fn() { ch.send(num * num) }()
  }
  var i = 0
  while i < 5 { io.log("square:", ch.recv()); i = i + 1 }
  io.log("PASS channel_fanout")
}