// Lunex — channel — pipeline
// Chain two goroutines with channels
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  val gen = channel()
  val out = channel()
  spawn fn() {
    var i = 1
    while i <= 5 { gen.send(i); i = i + 1 }
    gen.send(null)
  }()
  spawn fn() {
    while true {
      val v = gen.recv()
      if v == null { break }
      out.send(v * 2)
    }
    out.send(null)
  }()
  while true {
    val v = out.recv()
    if v == null { break }
    io.log("doubled:", v)
  }
  io.log("PASS channel_pipeline")
}