// Lunex — channel — collect
// Gather N results from parallel goroutines using native .push()
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io   = @import("std.io")
val math = @import("std.math")
fn main() {
  val items = ["alpha", "beta", "gamma", "delta", "epsilon"]
  val ch    = channel()
  each item in items {
    val it = item
    spawn fn() { ch.send({ name: it, id: math.floor(math.random() * 1000) }) }()
  }
  var results = []
  var i       = 0
  while i < 5 {
    results.push(ch.recv())
    i = i + 1
  }
  each r in results { io.log(r.name, "→", r.id) }
  io.log("PASS channel_collect")
}
