// Lunex — datetime — now
// Current time in various formats
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
val dt = @import("std.datetime")
fn main() {
  val now = dt.now()
  io.log("now:", now)
  io.log("ts:", dt.toTimestamp(now))
  io.log("fmt:", dt.format(now, "YYYY-MM-DD HH:mm:ss"))
  io.log("utc:", dt.utcNow())
  io.log("PASS datetime_now")
}
