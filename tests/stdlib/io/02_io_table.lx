// Lunex — io — table display
// Render tabular data
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io")
fn main() {
  val rows = [
    { name: "Alice",  role: "admin", score: 98 }
    { name: "Bob",    role: "user",  score: 74 }
    { name: "Carol",  role: "mod",   score: 85 }
  ]
  io.table(rows)
  io.log("PASS io_table")
}