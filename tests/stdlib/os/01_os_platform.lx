// Lunex — os — platform
// Runtime platform, arch, hostname
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io"); val os = @import("std.os")
fn main() {
  io.log("platform:", os.platform())
  io.log("arch:", os.arch())
  io.log("hostname:", os.hostname())
  io.log("pid:", os.pid())
  io.log("PASS os_platform")
}