// Lunex — crypto — base64
// Encode and decode with base64Encode / base64Decode
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io     = @import("std.io")
val crypto = @import("std.crypto")
fn main() {
  val orig = "Hello, Lunex! This is a test."
  val enc  = crypto.base64Encode(orig)
  val dec  = crypto.base64Decode(enc)
  io.log("encoded:", enc)
  io.log("decoded:", dec)
  io.log("round-trip:", orig == dec)
  io.log("PASS crypto_base64")
}
