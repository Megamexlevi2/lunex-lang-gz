// Lunex — crypto — hash
// SHA-256, MD5
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io"); val crypto = @import("std.crypto")
fn main() {
  val msg = "hello, lunex"
  io.log("sha256:", crypto.sha256(msg))
  io.log("md5:", crypto.md5(msg))
  io.log("deterministic:", crypto.sha256(msg) == crypto.sha256(msg))
  io.log("PASS crypto_hash")
}