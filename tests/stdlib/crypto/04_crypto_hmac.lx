// Lunex — crypto — HMAC
// Sign messages with HMAC-SHA256
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io"); val crypto = @import("std.crypto")
fn main() {
  val key  = "secret-key"
  val data = "payload:user=alice"
  val sig  = crypto.hmac(key, data)
  io.log("sig:", sig)
  io.log("deterministic:", sig == crypto.hmac(key, data))
  io.log("key matters:", sig != crypto.hmac("wrong", data))
  io.log("PASS crypto_hmac")
}