// Lunex — crypto — UUID v4
// Generate and verify uniqueness with randomUUID
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io     = @import("std.io")
val crypto = @import("std.crypto")
fn main() {
  var i = 0
  while i < 5 {
    io.log(" ", crypto.randomUUID())
    i = i + 1
  }
  io.log("unique:", crypto.randomUUID() != crypto.randomUUID())
  io.log("PASS crypto_uuid")
}
