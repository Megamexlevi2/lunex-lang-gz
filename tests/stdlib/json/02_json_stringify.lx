// Lunex — json — stringify
// Pretty JSON output with spaces and indentation

val io   = @import("std.io")
val json = @import("std.json")

fn main() {
  val user = {
    name: "Luna",
    age: 7,
    active: true,
    roles: ["admin", "writer"]
  }

  val text = json.stringify(user)
  io.log(text)
  io.log("contains_newline:", text.includes("\n"))
  io.log("contains_spaces:", text.includes("  "))
  io.log("PASS json_stringify")
}
