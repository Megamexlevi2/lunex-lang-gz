// Lunex — utils — object
// keys, values, merge
// Lunex v0.7.1 · github.com/Megamexlevi2/lunex-lang-gz

val io = @import("std.io"); val utils = @import("std.utils")
fn main() {
  val user  = { name: "Alice", age: 30, role: "admin" }
  val extra = { score: 100, verified: true }
  io.log("keys:", utils.keys(user))
  io.log("values:", utils.values(user))
  io.log("merged:", utils.merge(user, extra))
  io.log("PASS utils_object")
}