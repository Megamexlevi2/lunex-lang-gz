// Lunex — regex — find all matches
// Extract all non-overlapping matches with matchAll
// Lunex v0.8.1 · github.com/Megamexlevi2/lunex-lang-gz

val io    = @import("std.io")
val regex = @import("std.regex")
fn main() {
  val text = "order #1234 and order #5678"
  io.log("orders:", regex.matchAll(text, "#\\d+"))
  val emails = "contact alice@example.com or bob@test.org"
  io.log("emails:", regex.matchAll(emails, "[\\w.]+@[\\w.]+"))
  val numbers = "pi=3.14 e=2.71 phi=1.618"
  io.log("numbers:", regex.extractNumbers(numbers))
  io.log("PASS regex_find")
}
