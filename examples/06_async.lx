// Lunex 0.4.2 — Async / concurrency with channels
val io = @import("std.io")

fn fetchData(id) {
  // Simulate work
  val i = 0
  while i < 100000 { i = i + 1 }
  "data-" + id
}

fn main() {
  io.log("Fetching in background...")

  val ch = channel()

  spawn fn() {
    val result = fetchData(42)
    ch.send(result)
  }()

  // Do other work while fetch runs
  io.log("Doing other things...")

  val result = ch.recv()
  io.log("Got:", result)
}
