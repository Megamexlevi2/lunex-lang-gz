val io   = @import("std.io")
val math = @import("std.math")
val str  = @import("std.string")

fn main() {
  io.log("sqrt(2) = " + math.sqrt(2))
  io.log("floor(3.7) = " + math.floor(3.7))
  io.log("abs(-5) = " + math.abs(-5))

  val s = "Hello, NTL!"
  io.log(str.toUpper(s))
  io.log(str.toLower(s))
  io.log(str.replace(s, "NTL", "World"))

  val parts = str.split("a,b,c", ",")
  io.log(parts.join(" | "))
}
