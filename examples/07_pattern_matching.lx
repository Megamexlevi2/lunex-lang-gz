// Example 07 — Pattern matching
val io = @import("std.io")

// match on value with wildcard fallback
fn httpStatus(code) {
  match code {
    200 => "OK"
    201 => "Created"
    204 => "No Content"
    400 => "Bad Request"
    401 => "Unauthorized"
    403 => "Forbidden"
    404 => "Not Found"
    422 => "Unprocessable Entity"
    500 => "Internal Server Error"
    _   => "Unknown Status"
  }
}

// match used to classify without ranges (use if/else for ranges)
fn classify(n) {
  if n < 0 {
    "negative"
  } else if n == 0 {
    "zero"
  } else if n <= 10 {
    "small (1-10)"
  } else if n <= 99 {
    "medium (11-99)"
  } else {
    "large (100+)"
  }
}

fn dayName(d) {
  match d {
    1 => "Monday"
    2 => "Tuesday"
    3 => "Wednesday"
    4 => "Thursday"
    5 => "Friday"
    6 => "Saturday"
    7 => "Sunday"
    _ => "Invalid"
  }
}

fn main() {
  each n in [0, 1, 5, 50, 500] {
    io.log(n, "=>", classify(n))
  }

  io.log("")

  each code in [200, 201, 404, 500, 418] {
    io.log(code, "=>", httpStatus(code))
  }

  io.log("")

  each d in [1, 3, 5, 6, 9] {
    io.log("Day", d, "=>", dayName(d))
  }
}
