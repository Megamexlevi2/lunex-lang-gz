val io  = @import("std.io")
val math = @import("std.math")

fn main() {
  val name   = "Alice"
  val age    = 30
  val height = 1.75
  val active = true

  io.log("Name:   " + name)
  io.log("Age:    " + age)
  io.log("Height: " + height)
  io.log("Active: " + active)

  val square = fn(x) { x * x }
  io.log("5^2 = " + square(5))

  val pi = math.PI
  io.log("PI = " + pi)
}
