// Example 15 — Concurrent workers with channels
val io = @import("std.io")

fn main() {
  io.log("=== Concurrent workers ===")

  val ch = channel()

  fn worker(id) {
    var sum = 0
    var i   = 0
    while i < 1000 {
      sum = sum + i
      i   = i + 1
    }
    ch.send(struct {
      id  = id
      sum = sum
    })
  }

  spawn fn() { worker(1) }()
  spawn fn() { worker(2) }()
  spawn fn() { worker(3) }()

  val r1 = ch.recv()
  val r2 = ch.recv()
  val r3 = ch.recv()

  io.log("worker", r1.id, "sum:", r1.sum)
  io.log("worker", r2.id, "sum:", r2.sum)
  io.log("worker", r3.id, "sum:", r3.sum)

  io.success("All workers done!")
}
