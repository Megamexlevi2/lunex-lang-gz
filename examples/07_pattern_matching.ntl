val io = @import("std.io")

fn describe(x) {
  match x {
    0        => "zero"
    1        => "one"
    2..10    => "small (" + x + ")"
    _        => "large (" + x + ")"
  }
}

fn tagName(tag) {
  match tag {
    "h1"    => "Heading 1"
    "h2"    => "Heading 2"
    "p"     => "Paragraph"
    "span"  => "Span"
    _       => "Unknown <" + tag + ">"
  }
}

fn main() {
  each n in [0, 1, 5, 99] {
    io.log(describe(n))
  }
  each t in ["h1", "p", "div"] {
    io.log(tagName(t))
  }
}
