val io    = @import("std.io")
val os    = @import("std.os")
val paths = @fimport("../src/paths.lx")

var passed = 0
var failed = 0

fn check(label, got, expected) {
  if got == expected {
    io.log(io.green("  ✔") + " " + label)
    passed = passed + 1
  } else {
    io.log(io.red("  ✘") + " " + label)
    io.log(io.dim("    got:      " + str(got)))
    io.log(io.dim("    expected: " + str(expected)))
    failed = failed + 1
  }
}

fn checkContains(label, got, sub) {
  if got != null && got.includes(sub) {
    io.log(io.green("  ✔") + " " + label)
    passed = passed + 1
  } else {
    io.log(io.red("  ✘") + " " + label)
    io.log(io.dim("    got:         " + str(got)))
    io.log(io.dim("    should have: " + sub))
    failed = failed + 1
  }
}

fn main() {
  io.log(io.bold("paths.lx"))

  val home = paths.home()
  checkContains("home() returns a path",     home, "/")
  checkContains("lunaHome() ends in .luna",  paths.lunaHome(), ".luna")
  checkContains("packagesDir() ends in /packages", paths.packagesDir(), "/packages")
  checkContains("binDir() ends in /bin",     paths.binDir(), "/bin")
  checkContains("cacheDir() ends in /cache", paths.cacheDir(), "/cache")

  val pkgDir = paths.pkgDir("user/repo")
  check("pkgDir replaces slash with __", pkgDir, paths.packagesDir() + "/user__repo")

  val pkgDir2 = paths.pkgDir("simple")
  checkContains("pkgDir simple name", pkgDir2, "simple")

  io.log("")
  io.log(io.dim("  " + str(passed) + " passed, " + str(failed) + " failed"))
  io.log("")
}
