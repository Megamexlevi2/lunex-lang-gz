val io = @import("std.io")
val os = @import("std.os")
val fs = @import("std.fs")
val runtime = @fimport("../src/runtime.lx")

fn testsPrefix() {
  if fs.exists("tests/test-paths.lx") {
    ""
  } else if fs.exists("luna-pm/tests/test-paths.lx") {
    "luna-pm/"
  } else if fs.exists("../luna-pm/tests/test-paths.lx") {
    "../luna-pm/"
  } else {
    ""
  }
}

fn runTest(file) {
  val base = testsPrefix()
  io.log(io.dim("running " + file + "..."))
  val result = runtime.execLunex("run " + base + "tests/" + file)
  if result.stdout.length > 0 {
    io.log(result.stdout)
  }
  if !result.ok {
    io.log(io.red("  [FAILED] " + file))
    if result.stderr.length > 0 {
      io.log(io.dim(result.stderr))
    }
  }
}

fn main() {
  io.banner("Luna PM Test Suite")
  io.log("")

  runTest("test-paths.lx")
  runTest("test-github.lx")
  runTest("test-meta.lx")

  io.log(io.bold(io.green("Done.")))
}
